{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/roles/layout,_N_T_/roles/[slug]/layout,_N_T_/roles/[slug]/page,_N_T_/roles/front-desk-agent"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/roles/$d$slug/__PAGE__",
    "/roles/$d$slug",
    "/roles",
    "/_index",
    "/_head"
  ]
}