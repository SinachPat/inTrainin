# ── InTrainin Web — environment variables ──────────────────────────────────
# Copy this file to .env.local for local development.
# In Vercel (production), set these as Environment Variables in the dashboard.

# URL of the deployed Hono API (apps/api).
# Local dev:  http://localhost:3001
# Production: https://your-api.railway.app  (or Render / Fly.io URL)
NEXT_PUBLIC_API_URL=http://localhost:3001
