# ── InTrainin Web — environment variables ──────────────────────────────────
# Copy this file to .env.local for local development.

# API base URL — must match the running API server
NEXT_PUBLIC_API_URL=http://localhost:3001

# Paystack public key (Settings → API Keys → Public Key).
# Required for the buy-credits and enrol payment flows.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...
