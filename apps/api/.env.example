# ── InTrainin API — environment variables ──────────────────────────────────
# Copy this file to .env for local development.
# In Railway / Render / Fly.io, set these as service environment variables.

# Supabase project credentials (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — must match the one used to sign tokens in the auth domain
# Use: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret

# Allowed CORS origin — set to your Vercel deployment URL in production
# Local dev: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Port the API listens on (Railway sets PORT automatically)
PORT=3001

# ── Layer 8 (Paystack) — fill in when ready ────────────────────────────────
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_WEBHOOK_SECRET=whsec_...
