# ── InTrainin API — environment variables ──────────────────────────────────
# Copy this file to .env for local development.
# In Railway / Render / Fly.io, set these as service environment variables.

# Supabase project credentials (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase JWT secret — used to verify tokens issued by Supabase Auth
# Found in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Allowed CORS origin — set to your Vercel deployment URL in production
# Local dev: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Port the API listens on (Railway sets PORT automatically)
PORT=3001

# ── Layer 8 (Paystack) — fill in when ready ────────────────────────────────
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_WEBHOOK_SECRET=whsec_...
