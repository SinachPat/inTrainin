# ── InTrainin API — environment variables ──────────────────────────────────
# Copy this file to .env for local development.
# In Render / Fly.io, set these as service environment variables instead.

# Supabase project credentials (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Allowed CORS origin — set to your Vercel deployment URL in production
# Local dev: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Port the API listens on (Render sets PORT automatically — do not override)
PORT=3001

# ── Paystack ──────────────────────────────────────────────────────────────
# Secret key for server-side transaction verification (Settings → API Keys).
PAYSTACK_SECRET_KEY=sk_live_...
# Webhook secret — copy from Paystack dashboard → Webhooks → your endpoint.
PAYSTACK_WEBHOOK_SECRET=whsec_...
# Webhook URL to register in Paystack dashboard:
#   https://your-api-domain.com/notifications/webhooks/paystack

# ── Cron ──────────────────────────────────────────────────────────────────
# Shared secret for the monthly credits cron job (GitHub Actions).
# CRON_SECRET=your-random-secret
